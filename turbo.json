{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "generate": {
      "dependsOn": [],
      "outputs": ["node_modules/.prisma/**"]
    },
    "typecheck": {
      "dependsOn": ["generate", "^build"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["typecheck"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["typecheck"],
      "outputs": ["coverage/**"]
    },
    "test:security": {
      "dependsOn": ["typecheck"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["typecheck", "lint", "^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
