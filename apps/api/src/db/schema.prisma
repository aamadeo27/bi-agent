generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform"]
}

/// Tenant registry — one row per provisioned tenant.
model Tenant {
  id          String       @id
  slug        String       @unique @db.VarChar(63)
  displayName String       @map("display_name") @db.VarChar(256)
  status      TenantStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  ssoConfig TenantSsoConfig?

  @@map("tenants")
  @@schema("platform")
}

enum TenantStatus {
  active
  suspended

  @@schema("platform")
}

/// Global key-value configuration shared across all tenants.
model GlobalConfig {
  key       String   @id @db.VarChar(128)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("global_config")
  @@schema("platform")
}

/// Platform user — one row per human; email is global-unique.
model User {
  id           String     @id
  email        String     @unique @db.VarChar(320)
  passwordHash String     @map("password_hash") @db.Text
  displayName  String     @map("display_name") @db.VarChar(256)
  status       UserStatus @default(active)
  tenantId     String?    @map("tenant_id")
  roleId       String?    @map("role_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  refreshTokens RefreshToken[]

  @@map("users")
  @@schema("platform")
}

enum UserStatus {
  invited
  active
  suspended

  @@schema("platform")
}

/// Per-tenant OIDC / SSO configuration. clientSecret should be encrypted at rest (vault) before v1.
model TenantSsoConfig {
  id           String   @id
  tenantId     String   @unique @map("tenant_id")
  issuer       String   @db.VarChar(512)
  clientId     String   @map("client_id") @db.VarChar(256)
  clientSecret String   @map("client_secret") @db.Text
  callbackUrl  String   @map("callback_url") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_sso_configs")
  @@schema("platform")
}

/// Rotating refresh tokens — one active token per session.
model RefreshToken {
  id        String    @id
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@schema("platform")
}
