@@ -0,0 +1,44 @@
+# BI Result Presenter — local dev environment template
+# Copy to .env.local and fill in real values before running.
+# NEVER commit .env.local or any file matching .env* (blocked by .gitignore).
+
+# Control-plane Postgres URL (Prisma)
+DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bi_platform
+
+# Google Gemini API key
+GEMINI_API_KEY=your-gemini-api-key
+
+# JWT signing secrets — change before any real use
+JWT_ACCESS_SECRET=dev-access-secret-change-me
+JWT_REFRESH_SECRET=dev-refresh-secret-change-me
+
+# KMS key reference — use "local-test-key" in development (no-op stub)
+KMS_KEY_REF=local-test-key
+
+# Runtime
+NODE_ENV=development
+PORT=3000
+LOG_LEVEL=debug
+
+# LLM provider selection
+LLM_PROVIDER=gemini
+LLM_MODEL=gemini-1.5-flash
+
+# Result / chart thresholds (GAP-8)
+RESULT_ROW_CAP=10000
+CHART_DOWNGRADE_ROW_THRESHOLD=2000
+
+# Conversation history retention in days (GAP-4)
+HISTORY_RETENTION_DAYS=365
+
+# SPA → API base URL (non-secret; Vite exposes VITE_* vars to the browser)
+VITE_API_URL=http://localhost:3000
+
+# OpenTelemetry (optional; points at a local collector when running --profile observability)
+OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
+
+# Error-tracking sink (optional, dev-only bootstrap hook).
+# Leave UNSET to disable — the sink no-ops gracefully and errors still log via pino.
+# Set to a Sentry DSN (free tier) to capture unhandled errors locally.
+# Production alerting/release routing is epic-007 (T7.3/T7.4), NOT configured here.
+# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
