diff --git a/apps/web/nginx.conf b/apps/web/nginx.conf
new file mode 100644
index 0000000..cfc895d
--- /dev/null
+++ b/apps/web/nginx.conf
@@ -0,0 +1,25 @@
+server {
+    listen 80;
+    server_name _;
+
+    root /usr/share/nginx/html;
+    index index.html;
+
+    # Serve pre-compressed assets when available
+    gzip_static on;
+
+    location / {
+        # SPA fallback: unknown paths served as index.html so React Router handles routing
+        try_files $uri $uri/ /index.html;
+    }
+
+    # Cache fingerprinted static assets aggressively; index.html must revalidate
+    location ~* \.(js|css|png|jpg|jpeg|svg|ico|woff2?)$ {
+        expires 1y;
+        add_header Cache-Control "public, immutable";
+    }
+
+    location = /index.html {
+        add_header Cache-Control "no-cache";
+    }
+}
